<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="Cycloside.SkinThemeEditorWindow"
        Width="600" Height="450"
        Title="Theme Editor">
    <DockPanel Margin="10" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4">
            <ComboBox x:Name="ScopeBox" Width="160"/>
            <ComboBox x:Name="FileBox" Width="280"/>
            <Button Content="Load" Click="LoadFile"/>
            <Button Content="Save" Click="SaveFile"/>
            <Button Content="Preview" Click="PreviewSkin"/>
        </StackPanel>
        <TextBlock x:Name="SelectedPathBlock"
                   DockPanel.Dock="Top"
                   Margin="0,6,0,0"
                   TextWrapping="Wrap"/>
        
        <ae:TextEditor x:Name="Editor" Margin="0,8,0,0" FontFamily="monospace"/>
        
    </DockPanel>
</Window>
