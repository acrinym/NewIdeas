<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource CanvasBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
  </Style>

  <Style Selector="Button">
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusL}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Background" Value="#66FFFFFF"/>
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    <Setter Property="BorderBrush" Value="#88FFFFFF"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#88FFFFFF"/>
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusM}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Background" Value="#44FFFFFF"/>
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    <Setter Property="BorderBrush" Value="#88FFFFFF"/>
    <Setter Property="CaretBrush" Value="{DynamicResource SystemAccentBrush}"/>
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusM}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Background" Value="#44FFFFFF"/>
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    <Setter Property="BorderBrush" Value="#88FFFFFF"/>
  </Style>

  <Style Selector="TabItem">
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusM}"/>
    <Setter Property="Padding" Value="12,6"/>
  </Style>

  <Style Selector="TabItem:selected">
    <Setter Property="Background" Value="#88FFFFFF"/>
  </Style>

</Styles>
