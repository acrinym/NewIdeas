<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cycloside.SkinPreviewWindow"
        Width="520" Height="420"
        Title="Skin Preview">
    <DockPanel Margin="14">
        <TextBlock x:Name="PreviewStatus"
                   DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Text="Preview ready." />
        <Border Padding="14"
                CornerRadius="8"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1">
            <ContentControl x:Name="PreviewHost" />
        </Border>
    </DockPanel>
</Window>
