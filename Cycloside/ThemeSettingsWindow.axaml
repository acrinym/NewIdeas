<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cycloside.ThemeSettingsWindow"
        Width="360" Height="380"
        Title="Theme Settings">
    <DockPanel Margin="10">
        <ScrollViewer>
            <StackPanel>
                <StackPanel x:Name="ThemePanel" />
                <Separator Margin="0,10,0,4"/>
                <TextBlock x:Name="ManifestHeader" Text="Theme Info" FontWeight="Bold" Margin="0,0,0,4"/>
                <Border x:Name="ManifestPanel" Background="{DynamicResource ThemeBackgroundBrush}" Padding="8" CornerRadius="4">
                    <StackPanel x:Name="ManifestContent" Spacing="4"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Button DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,4,0,0" Content="Save" Click="SaveButton_Click"/>
    </DockPanel>
</Window>
